# =========================================================
#  DeviceBridge Pro — environment variables
#  Copy to `.env.local` for local dev. On Vercel, set in
#  Project Settings -> Environment Variables.
# =========================================================

# ---- REQUIRED ----
# Admin panel login password (choose a strong one)
ADMIN_PASSWORD=change-me-to-a-strong-password

# JWT signing secret for device tokens (MUST be >= 32 chars)
# generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters-long

# Public base URL of THIS panel (where the APK will connect).
# Local dev: http://localhost:3000
# Prod:      https://your-panel.vercel.app  (set AFTER first deploy)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---- OPTIONAL (Vercel storage — auto-wired when enabled in dashboard) ----
# Vercel KV (device records, command queue, telemetry)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob (media: photos / audio / screenshots)
# BLOB_READ_WRITE_TOKEN=
